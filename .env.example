# Environment Variables

# PostgreSQL connection string (required for the server and Drizzle ORM)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Server port (optional, defaults to 5000)
PORT=5000

# Node environment (development | production)
NODE_ENV=development

# ---------------------------------------------------------------------------
# Replit (automatic – no action required)
# ---------------------------------------------------------------------------
# REPL_ID is set automatically by the Replit environment. It is used in
# vite.config.ts to conditionally load Replit-specific dev plugins.
# Do NOT set this variable manually.
